# --- Live scoring ---
# Required to enable /clients/new (the SCORER endpoint).
# When unset, the form loads but stays disabled with a clear note.
ANTHROPIC_API_KEY=

# --- Feedback widget ---
# Optional. If unset, /api/feedback accepts feedback and logs it
# server-side without forwarding. Set this to a Slack incoming
# webhook URL in Vercel project settings to forward feedback to Slack.
FEEDBACK_WEBHOOK_URL=
